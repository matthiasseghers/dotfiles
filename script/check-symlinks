#!/usr/bin/env bash
#
# Check for .symlink files whose basename would resolve to a known system path under $HOME

BLOCKED="config ssh local cache bash_history zsh_history"
fail=0

for f in $(find . -name '*.symlink' -not -path './.git/*'); do
  name=$(basename "${f%.*}")
  for blocked in $BLOCKED; do
    if [ "$name" = "$blocked" ]; then
      echo "ERROR: $f would create ~/.$name — use an install.sh instead"
      fail=1
    fi
  done
done

exit $fail
