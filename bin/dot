#!/usr/bin/env bash
#
# dot
#
# `dot` handles installation, updates, things like that. Run it periodically
# to make sure you're on the latest and greatest.

set -e

parentDirectory="$(cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd -P)"
dotfilesDirectory="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"

displayUsageAndExit() {
	echo "dot -- dotfiles management"
	echo ""
	echo "Usage: dot [options]"
	echo ""
	echo "Options:"
	echo "  -e, --edit    Open dotfiles directory for editing"
	echo "  -h, --help    Show this help message and exit"
	exit
}

while test $# -gt 0; do
	case "$1" in
		"-h"|"--help")
			displayUsageAndExit
			;;
		"-e"|"--edit")
			exec "$EDITOR" "$dotfilesDirectory"
			exit
			;;
		*)
			echo "Invalid option: $1"
			displayUsageAndExit
			;;
	esac

done

ZSH="$(cd "$( dirname "$parentDirectory" )" && pwd -P)"
export ZSH

# Update dotfiles themselves
if git -C "$ZSH" remote get-url origin 2>/dev/null | grep -q '^https://'; then
	echo "› git pull skipped (remote is HTTPS — switch to SSH: git remote set-url origin git@github.com:USER/dotfiles.git)"
elif git -C "$ZSH" diff --quiet && git -C "$ZSH" diff --cached --quiet 2>/dev/null; then
	echo "› git pull"
	git -C "$ZSH" pull 2>&1 || echo "› git pull failed — SSH key may not be set up yet"
else
	echo "› git pull skipped (uncommitted changes in dotfiles repo)"
fi

# Install homebrew
"$ZSH"/homebrew/install.sh 2>&1

# Upgrade homebrew
echo "› brew update"
brew update

echo "› brew upgrade"
brew upgrade

# Install software
echo "› script/install"
"$ZSH"/script/install
